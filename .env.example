# Copy this file to .env and fill in your values.

# The token for the sidecar Discord bot that will listen for reactions.
DISCORD_BOT_TOKEN=

# The Discord User ID of the main Hermes Agent bot. The sidecar will only monitor reactions on messages sent by this ID.
HERMES_AGENT_USER_ID=12345678901234567890

# A comma-separated list of Discord User IDs that are allowed to record scores. Leave empty to allow anyone.
REACTION_ALLOWED_USER_IDS=

# Path to the SQLite mapping database created by the Hermes gateway hook.
DISCORD_TURN_MAP_DB_PATH=data/discord_turn_map.db

# Path to the main Hermes state database where tool execution logs are stored.
HERMES_STATE_DB_PATH=~/.hermes/state.db

# Path where the sidecar bot will store the human skill review scores.
SKILL_AUDIT_DB_PATH=data/skill_audit.db

# How long (in seconds) the mapper should wait to match an assistant row after the Discord message is sent.
TURN_MAP_DEFAULT_WINDOW_SECONDS=180

# Extended fallback window (in seconds) used to rescue heavily delayed mappings.
TURN_MAP_RESCUE_WINDOW_SECONDS=600
